generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String @unique
  password  String
  role      String
  createdAt DateTime @default(now())
}

model Log {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  value     String
  createdAt DateTime @default(now())
}

model Scheduling {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  patientName String
  email       String
  specialty   String
  date        String
  time        String
  status      String @default("AGENDADO")
}